# ===========================================================================
# EXAMPLE ENVIRONMENT VARIABLES  (Week 3)
# Project: Supply Chain & Logistics Optimizer
# ===========================================================================
#
# HOW TO USE
#   1. Copy this file to a new file named ".env" in the project root:
#          cp .env.example .env        (macOS/Linux)
#          copy .env.example .env      (Windows)
#   2. Fill in DATABASE_PASSWORD with your real local PostgreSQL password.
#   3. NEVER commit your real .env file. Only .env.example is committed.
#
# The code reads these values in database/config.py via python-dotenv.
# If a variable is missing, a safe local-development default is used
# (but the password default is empty - you must set it).
# ===========================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=supply_chain_optimizer
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# ---------------------------------------------------------------------------
# API settings (Week 4). These are OPTIONAL - the code has safe defaults, so
# the API runs even if you do not set any of them. They are read in
# api/config.py via pydantic-settings. All API variables start with "API_".
# ---------------------------------------------------------------------------
# Human-readable info shown at the top of the auto-generated documentation.
API_TITLE=Supply Chain & Logistics Optimizer API
API_VERSION=0.4.0
# How many rows a "list" endpoint returns per page by default, and the max a
# caller is allowed to request in one page (protects the server).
API_DEFAULT_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100
# Comma-separated list of browser origins allowed to call the API (CORS).
# "*" means "any origin" - fine for local development; tighten before deploy.
API_CORS_ORIGINS=*

# ---------------------------------------------------------------------------
# Optimization settings (Week 5). These are OPTIONAL - the engine has safe
# defaults, so the optimizers run even if you set none of them. They are read
# in optimization/config.py via pydantic-settings. All start with "OPT_".
# ---------------------------------------------------------------------------
# The most wall-clock time the OR-Tools CP-SAT solver may spend on one solve.
# A limit guarantees an endpoint always returns promptly (best plan so far).
OPT_SOLVER_TIME_LIMIT_SECONDS=5.0
# CP-SAT worker threads (0 = let the solver decide).
OPT_SOLVER_WORKERS=8
# Straight-line distances are scaled by this to approximate real road distance.
# 1.30 matches the winding factor Week 2 used for delivery_routes.
OPT_WINDING_FACTOR=1.30
# The Olist data has no per-shipment package count, so one is simulated in this
# range (deterministically from the shipment id). Tune to loosen/tighten the
# vehicle-capacity constraints.
OPT_MIN_PACKAGES_PER_SHIPMENT=1
OPT_MAX_PACKAGES_PER_SHIPMENT=10
# Fleet reporting thresholds: above overloaded = a stress signal; below
# underutilized = wasteful. The hard capacity limit is always 1.0 (100%).
OPT_OVERLOADED_UTILIZATION=0.90
OPT_UNDERUTILIZED_UTILIZATION=0.30
# Safety caps on how much work a single optimization request may include, so a
# call can never build an enormous, slow model.
OPT_MAX_SHIPMENTS_PER_REQUEST=300
OPT_MAX_ROUTE_STOPS_PER_REQUEST=100
OPT_MAX_WAREHOUSE_DEMANDS_PER_REQUEST=200

# ---------------------------------------------------------------------------
# Optimization EXECUTION settings (Week 6). OPTIONAL - safe defaults exist, so
# the execution layer runs with none of these set. Read in
# optimization/execution_config.py via pydantic-settings. All start with "OPT_".
# These are the KPI pricing / reporting knobs of the execution layer. The per-km
# default matches the rate Week 2 used for delivery_routes.estimated_cost.
# ---------------------------------------------------------------------------
# Per-km rate used to price a plan that has no vehicle rate (routes, warehouse).
OPT_DEFAULT_COST_PER_KM=1.20
# Cost of holding ONE unit of stock for the reporting period (a simulated
# accounting figure): inventory holding cost = units on hand * this rate.
OPT_INVENTORY_HOLDING_COST_PER_UNIT=0.10
# "Late deliveries" is a documented PROXY: a shipment on a vehicle loaded above
# this fraction of capacity is flagged at risk of being late (0.90 = "overloaded").
OPT_LATE_DELIVERY_LOAD_THRESHOLD=0.90
# CP-SAT worker threads for NORMAL production requests (0 = let the solver decide).
# The reproducible benchmark below ignores this and always uses a single worker.
OPT_SOLVER_WORKERS=8

# ---------------------------------------------------------------------------
# BENCHMARK / REPRODUCIBILITY settings (Week 6 reproducibility fix). OPTIONAL.
# These control notebooks/week6_benchmark_runner.py and the reproducibility
# check; they are top-level variables (NO prefix). None are required.
# ---------------------------------------------------------------------------
# Turn on deterministic solver mode: a SINGLE CP-SAT worker, a fixed seed (42),
# and a deterministic-time stop instead of wall-clock. This is what makes the
# benchmark's business metrics identical across repeated runs and across
# machines (Windows/local vs AWS EC2). The benchmark runner turns this ON by
# default; set it to false only to reproduce the older multi-worker behaviour.
BENCHMARK_DETERMINISTIC=true
# Pin an explicit warehouse for the whole benchmark sweep. If unset, the runner
# resolves ONE default warehouse deterministically (most available vehicles;
# ties broken by smallest warehouse_id) and reuses it for every scenario.
# BENCHMARK_WAREHOUSE_ID=WH-0003
# Which optimizer to benchmark, and how many shipments per run.
BENCHMARK_OPTIMIZER=assignment
BENCHMARK_MAX_SHIPMENTS=50

# ---------------------------------------------------------------------------
# AI multi-agent ORCHESTRATION settings (Week 7). OPTIONAL - the orchestration
# layer runs with none of these set, in a DETERMINISTIC mode (no LLM, no
# network). Read in agents/config.py via pydantic-settings. All start with
# "AGENT_". Setting them ONLY matters if you also install crewai and provide an
# LLM API key below, which unlocks the richer "crewai" reasoning/narration mode.
# ---------------------------------------------------------------------------
# Master switch. false forces the deterministic pipeline even if crewai + a key
# are present (handy for reproducible demos and tests).
AGENT_ENABLED=true
# The LLM provider and model used ONLY in the crewai mode. CrewAI talks to
# models through LiteLLM, so any provider it supports works; the default is
# OpenAI. Set AGENT_LLM_PROVIDER=anthropic (and ANTHROPIC_API_KEY) to use Claude.
AGENT_LLM_PROVIDER=openai
AGENT_LLM_MODEL=gpt-4o-mini
# Low temperature keeps an operations planner steady rather than creative.
AGENT_LLM_TEMPERATURE=0.2
# Print CrewAI's step-by-step reasoning to the console when the crew runs.
AGENT_VERBOSE=false
# A safety ceiling (seconds) on a single crew run so a stuck LLM cannot hang.
AGENT_CREW_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# LLM API KEY (Week 7, OPTIONAL). Only needed to enable the crewai mode. The
# orchestration layer detects whether the configured provider's key is present
# and, if not, silently runs the deterministic pipeline instead. NEVER commit a
# real key - only this example file is committed.
# ---------------------------------------------------------------------------
# For the default OpenAI provider:
OPENAI_API_KEY=your_openai_api_key_here
# For the Anthropic provider (if AGENT_LLM_PROVIDER=anthropic):
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Analytics DASHBOARD settings (Week 8). OPTIONAL - the dashboard has safe
# defaults, so `streamlit run dashboard/app.py` works with none of these set.
# Read in dashboard/config.py via pydantic-settings. All start with "DASHBOARD_".
# The dashboard needs NO secrets and stores none - it only needs the backend URL
# (any LLM key for the Week 7 crewai mode lives on the BACKEND, never here).
# ---------------------------------------------------------------------------
# WHERE the backend is. Default matches `uvicorn api.main:app --reload` locally;
# point it at a deployed backend to run the dashboard against a remote API.
DASHBOARD_API_BASE_URL=http://127.0.0.1:8000
# How long (seconds) to wait for the backend before showing a friendly timeout.
# An agent decision runs a real optimization, so the default is generous.
DASHBOARD_REQUEST_TIMEOUT_SECONDS=30
# Display guardrails: default rows per history page, the max a user may request
# (mirrors the backend's API_MAX_PAGE_SIZE), and the most rows any chart plots.
DASHBOARD_DEFAULT_PAGE_SIZE=50
DASHBOARD_MAX_PAGE_SIZE=100
DASHBOARD_CHART_ROW_LIMIT=200
# Show extra explanatory captions aimed at a first-time viewer (a walkthrough).
DASHBOARD_DEMO_MODE=true
